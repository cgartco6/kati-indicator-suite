# Binance API Keys (testnet recommended)
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
